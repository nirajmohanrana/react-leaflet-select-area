{
  "name": "react-leaflet-select-area",
  "description": "A simple React component for selecting an area on a Leaflet map.",
  "version": "2.0.0",
  "main": "dist/index.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "type": "module",
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "build": "rollup -c",
    "build:examples": "pnpm --filter examples build",
    "dev:examples": "pnpm --filter examples dev",
    "lint:examples": "pnpm --filter examples lint",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "react",
    "leaflet",
    "select-area",
    "react-leaflet",
    "react-leaflet-v4"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nirajmohanrana/react-leaflet-select-area.git"
  },
  "homepage": "https://react-leaflet-select-area.vercel.app/",
  "bugs": {
    "url": "https://github.com/nirajmohanrana/react-leaflet-select-area/issues"
  },
  "author": "Niraj Rana",
  "license": "MIT",
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "rollup": "^4.60.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2"
  }
}
